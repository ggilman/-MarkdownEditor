        <Window x:Class="MarkdownEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Markdown Editor" Height="720" Width="1200" MinHeight="500" MinWidth="800"
        Icon="markdown-icon.ico">
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Name="NewMenuItem" Click="NewButton_Click" InputGestureText="Ctrl+N" />
                <MenuItem Header="_Open..." Name="OpenMenuItem" Click="ImportButton_Click" InputGestureText="Ctrl+O" />
                <MenuItem Header="_Save..." Name="SaveMenuItem" Click="SaveButton_Click" InputGestureText="Ctrl+S" />
                <Separator />
                <MenuItem Header="E_xit" Name="ExitMenuItem" Click="ExitMenuItem_Click" InputGestureText="Alt+F4" />
            </MenuItem>
            <MenuItem Header="_Export">
                <MenuItem Header="Export to _Word (.docx)..." Name="ExportWordMenuItem" Click="ExportButton_Click" />
                <MenuItem Header="Export to _PDF..." Name="ExportPdfMenuItem" Click="ExportPdfButton_Click" />
                <Separator />
                <MenuItem Header="Auto-number headings" Name="AutoNumberHeadingsMenuItem" IsCheckable="True" IsChecked="True"
                          ToolTip="Automatically number headings in Word export (strips manual numbers from markdown)" />
                <MenuItem Header="# as Title" Name="UseTitleStyleMenuItem" IsCheckable="True" IsChecked="True"
                          ToolTip="Use Title style for # (H1 becomes Title, ## becomes Heading 1, etc.)" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Markdown Editor" Name="ViewMarkdownMenuItem" IsCheckable="True" IsChecked="False" Click="ViewMarkdownMenuItem_Click" />
                <MenuItem Header="Formatted Preview" Name="ViewPreviewMenuItem" IsCheckable="True" IsChecked="True" Click="ViewPreviewMenuItem_Click" />
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top" Background="#F5F5F5">
            <ToolBar Background="Transparent" ToolBarTray.IsLocked="True">
                <Button Name="ToolbarNewButton" Click="NewButton_Click" ToolTip="New document (Ctrl+N)" Padding="6,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="16" Margin="0,0,4,0">📄</TextBlock>
                        <TextBlock>New</TextBlock>
                    </StackPanel>
                </Button>
                <Button Name="ToolbarOpenButton" Click="ImportButton_Click" ToolTip="Open markdown file (Ctrl+O)" Padding="6,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="16" Margin="0,0,4,0">📂</TextBlock>
                        <TextBlock>Open</TextBlock>
                    </StackPanel>
                </Button>
                <Button Name="ToolbarSaveButton" Click="SaveButton_Click" ToolTip="Save markdown file (Ctrl+S)" Padding="6,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="16" Margin="0,0,4,0">💾</TextBlock>
                        <TextBlock>Save</TextBlock>
                    </StackPanel>
                </Button>
                <Separator Name="ToolbarSeparator1" />
                <Button Name="ToolbarBoldButton" Click="BoldButton_Click" ToolTip="Bold (Ctrl+B)" Padding="6,4" FontWeight="Bold">B</Button>
                <Button Name="ToolbarItalicButton" Click="ItalicButton_Click" ToolTip="Italic (Ctrl+I)" Padding="6,4" FontStyle="Italic">I</Button>
                <Button Name="ToolbarStrikeButton" Click="StrikethroughButton_Click" ToolTip="Strikethrough" Padding="6,4">
                    <TextBlock TextDecorations="Strikethrough">S</TextBlock>
                </Button>
                <Button Name="ToolbarCodeButton" Click="InlineCodeButton_Click" ToolTip="Inline code (Ctrl+Shift+K)" Padding="6,4" FontFamily="Consolas">&lt;/&gt;</Button>
                <Separator Name="ToolbarSeparator2" />
                <Button Name="ToolbarLinkButton" Click="LinkButton_Click" ToolTip="Insert link (Ctrl+K)" Padding="6,4">🔗</Button>
                <Button Name="ToolbarImageButton" Click="ImageButton_Click" ToolTip="Insert image" Padding="6,4">🖼️</Button>
                <Separator Name="ToolbarSeparator3" />
                <Button Name="ToolbarBulletButton" Click="BulletListButton_Click" ToolTip="Bullet list (Ctrl+Shift+8)" Padding="6,4">• List</Button>
                <Button Name="ToolbarNumberButton" Click="NumberedListButton_Click" ToolTip="Numbered list (Ctrl+Shift+7)" Padding="6,4">1. List</Button>
                <Button Name="ToolbarQuoteButton" Click="QuoteButton_Click" ToolTip="Quote (Ctrl+Shift+Q)" Padding="6,4">" Quote</Button>
                <Separator Name="ToolbarSeparator4" />
                <TextBlock Name="HeadingLabel" VerticalAlignment="Center" Margin="8,0,4,0" Foreground="#666">Heading:</TextBlock>
                <ComboBox Name="HeadingComboBox" Width="60" SelectedIndex="1" SelectionChanged="HeadingComboBox_SelectionChanged" ToolTip="Insert heading">
                    <ComboBoxItem>H1</ComboBoxItem>
                    <ComboBoxItem>H2</ComboBoxItem>
                    <ComboBoxItem>H3</ComboBoxItem>
                    <ComboBoxItem>H4</ComboBoxItem>
                    <ComboBoxItem>H5</ComboBoxItem>
                    <ComboBoxItem>H6</ComboBoxItem>
                </ComboBox>
                <Button Name="ToolbarHeadingButton" Click="HeadingApplyButton_Click" ToolTip="Apply heading (Ctrl+2)" Padding="6,4" Margin="4,0,0,0">Apply</Button>
            </ToolBar>
        </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom" Background="#F5F5F5">
            <StatusBarItem>
                <TextBlock Name="StatusText" Foreground="#555">Ready</TextBlock>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Name="EditorColumn" Width="*" />
                <ColumnDefinition Name="SplitterColumn" Width="10" />
                <ColumnDefinition Name="PreviewColumn" Width="*" />
            </Grid.ColumnDefinitions>

            <Border Name="EditorBorder" Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="8"
                    AllowDrop="True"
                    PreviewDragOver="EditorBorder_PreviewDragOver"
                    PreviewDrop="EditorBorder_PreviewDrop">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,6">Raw Markdown</TextBlock>
                    <TextBox Name="EditorTextBox"
                             Grid.Row="1"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             FontSize="14"
                             AllowDrop="True"
                             PreviewDragOver="EditorTextBox_PreviewDragOver"
                             PreviewDrop="EditorTextBox_PreviewDrop"
                             Drop="EditorTextBox_Drop"
                             TextChanged="EditorTextBox_TextChanged"
                             PreviewKeyDown="EditorTextBox_PreviewKeyDown"/>
                </Grid>
            </Border>

            <GridSplitter Name="ViewSplitter" Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#EEE" />

            <Border Name="PreviewBorder" 
                    Grid.Column="2" 
                    BorderBrush="#DDD" 
                    BorderThickness="1" 
                    CornerRadius="6" 
                    Padding="8"
                    AllowDrop="True"
                    PreviewDragOver="PreviewBorder_PreviewDragOver"
                    PreviewDrop="PreviewBorder_PreviewDrop">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,6">Formatted Preview (Read Only)</TextBlock>
                    <wv2:WebView2 Name="PreviewBrowser" 
                                  Grid.Row="1"
                                  DefaultBackgroundColor="White"
                                  NavigationStarting="PreviewBrowser_NavigationStarting"/>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
