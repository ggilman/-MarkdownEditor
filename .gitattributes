# Auto detect text files and perform LF normalization
* text=auto

# Markdown files
*.md text eol=lf encoding=utf-8

# Source code
*.cs text eol=lf encoding=utf-8
*.csproj text eol=lf encoding=utf-8
*.sln text eol=lf encoding=utf-8
*.xaml text eol=lf encoding=utf-8

# Configuration files
*.json text eol=lf encoding=utf-8
*.xml text eol=lf encoding=utf-8
*.config text eol=lf encoding=utf-8

# Documentation
*.txt text eol=lf encoding=utf-8
LICENSE text eol=lf encoding=utf-8
README text eol=lf encoding=utf-8

# Binary files
*.dll binary
*.exe binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
